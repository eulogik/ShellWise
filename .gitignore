htmlcov/

# Environment
.env
.env.local

# Models (large files, download on first run)
~/.shellwise/models/

# Logs
*.log

# Misc
*.tmp
*.bak

# Bundled llama-server binaries (regenerated by tools/fetch_binaries.py)
# ~200MB across 4 platforms — keep them out of git
shellwise/bin/darwin-arm64/*
shellwise/bin/darwin-x64/*
shellwise/bin/linux-x64/*
shellwise/bin/win32/*

# Local code index (regenerated by editor tooling)
.codegraph/

# CodeGraph data files
*.db
*.db-wal
*.db-shm
